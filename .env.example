# Database
DATABASE_URL="file:./dev.db"

# PriceCharting API
# Get your key at https://www.pricecharting.com/api
PRICECHARTING_API_KEY=""

# PSA API (optional — for cert lookup)
# https://www.psacard.com/pop/api
PSA_API_KEY=""

# eBay sold-listings scraper (optional but strongly recommended)
# Without this, falls back to HTML scraping which may be blocked.
# Free developer account + App ID: https://developer.ebay.com/my/keys
EBAY_APP_ID=""

# SNKRDUNK JPY→USD conversion rate (optional, default ~149 JPY/USD)
# Update when the exchange rate changes significantly.
SNKRDUNK_JPY_USD_RATE="0.0067"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Catalog sync ─────────────────────────────────────────────────────────────
# Secret that protects POST /api/catalog/sync from unauthorized triggers.
# Set the same value in Vercel → Settings → Environment Variables → CRON_SECRET
# Vercel cron jobs inject this automatically as: Authorization: Bearer <secret>
CRON_SECRET="change-me-to-a-random-string"

# Pokemon TCG API key (optional but recommended – raises rate limit to 20k/day)
# Free key at https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=""

# Comma-separated admin emails allowed to run /api/products/sync
# Example: "admin@example.com,ops@example.com"
# If unset, sync is allowed only in non-production environments.
SYNC_ADMIN_EMAILS=""
