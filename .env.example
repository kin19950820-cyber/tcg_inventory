# Database
DATABASE_URL="file:./dev.db"

# PriceCharting API
# Get your key at https://www.pricecharting.com/api
PRICECHARTING_API_KEY=""

# PSA API (optional — for cert lookup)
# https://www.psacard.com/pop/api
PSA_API_KEY=""

# eBay scraping (optional)
EBAY_APP_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Catalog sync ─────────────────────────────────────────────────────────────
# Secret that protects POST /api/catalog/sync from unauthorized triggers.
# Set the same value in Vercel → Settings → Environment Variables → CRON_SECRET
# Vercel cron jobs inject this automatically as: Authorization: Bearer <secret>
CRON_SECRET="change-me-to-a-random-string"

# Pokemon TCG API key (optional but recommended — raises rate limit to 20k/day)
# Free key at https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=""
